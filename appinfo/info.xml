<?xml version='1.0' encoding='UTF-8'?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
    <id>external_folder_refresh</id>
    <name>External Folder Refresh</name>
    <summary>Refresh the currently opened external folder without recursive scanning.</summary>
    <description>Adds a button to the Files interface that performs a shallow scan of the current folder. It is intended for external storages where remote changes are not immediately visible.</description>
    <version>0.2.0</version>
    <licence>agpl</licence>
    <author>Hawk/itxp</author>
    <namespace>ExternalFolderRefresh</namespace>
    <category>files</category>
    <website>https://github.com/iamhawk/external_folder_refresh</website>
    <bugs>https://github.com/iamhawk/external_folder_refresh/issues</bugs>
    <repository type="git">https://github.com/iamhawk/external_folder_refresh.git</repository>
    <dependencies>
        <nextcloud min-version="33" max-version="33" />
    </dependencies>
    <settings>
        <admin>OCA\ExternalFolderRefresh\Settings\AdminSettings</admin>
        <admin-section>OCA\ExternalFolderRefresh\Sections\AdminSection</admin-section>
    </settings>
</info>